# DaktariTB MCP Server — Environment Variables
#
# Copy this file to `.env` and fill in values for local development.
# `.env` is gitignored — never commit real values.
#
# At runtime inside Prompt Opinion, FHIR context comes from request headers
# (X-FHIR-Server-URL, X-FHIR-Access-Token, X-Patient-ID) — not from here.
# This file is only for local testing and server-level config.

# --- Server config ---
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=info

# --- Optional: local FHIR server for dev testing ---
# When Prompt Opinion calls us, it passes the FHIR URL in the X-FHIR-Server-URL
# header. For local testing we can point at a public sandbox or our own server.
DEV_FHIR_BASE_URL=https://app.promptopinion.ai/api/workspaces/YOUR_WORKSPACE_ID/fhir
DEV_FHIR_ACCESS_TOKEN=

# --- Kenya MOH TB-001 form config ---
# Facility code assigned by MOH — appears on the TB notification form.
# Leave blank for local dev; production deployments set per-facility.
MOH_FACILITY_CODE=
MOH_FACILITY_NAME=

# --- Observability ---
# Toggle verbose request logging. Disable in production.
DEBUG_LOG_REQUESTS=false
